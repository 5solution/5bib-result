# Core
NODE_ENV=development
NETWORK=testnet
PORT=8081

# MongoDB (main)
MONGODB_URL=mongodb://localhost:27018
MONGODB_DB_NAME=5bib_result

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=5bib-result-secret

# AWS S3 (main bucket for race assets)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=5bib-assets
AWS_S3_CDN_URL=

# Mailchimp transactional
MAILCHIMP_API_KEY=

# 5BIB Platform MySQL (readonly — leave blank to disable)
PLATFORM_DB_HOST=
PLATFORM_DB_PORT=3306
PLATFORM_DB_NAME=
PLATFORM_DB_USER=
PLATFORM_DB_PASS=

# Team Management — Volunteer MySQL (leave blank to disable the module)
VOLUNTEER_DB_HOST=
VOLUNTEER_DB_PORT=3306
VOLUNTEER_DB_NAME=
VOLUNTEER_DB_USER=
VOLUNTEER_DB_PASS=

# Team Management — misc
MAGIC_TOKEN_EXPIRES_DAYS=7
TEAM_S3_BUCKET=5sport-media
TEAM_CREW_BASE_URL=https://crew.5bib.com
TEAM_EMAIL_FROM=info@5bib.com
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=60

# Cloudflare Turnstile (free captcha) — used for /recover endpoints.
# Get free keys at https://dash.cloudflare.com → Turnstile → Add Site.
# If unset, backend skips verification (dev / self-hosted only — NEVER in prod).
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Result Image Creator v1.0
# Max concurrent canvas renders (per backend instance). Tune per CPU count;
# 8 is safe on a 4-vCPU VPS (napi-rs/canvas is native multi-threaded).
RENDER_MAX_CONCURRENT=8
# Public URL embedded in QR code + share links drawn on the image.
RESULT_PUBLIC_URL=https://result.5bib.com

# Event Tracking — behavioral analytics ingest from 5bib.com frontend
# Must match NEXT_PUBLIC_ANALYTICS_API_KEY on 5bib.com. Use a random secret in prod.
ANALYTICS_API_KEY=dev-analytics-key-local

# Timing Miss Alert v1.0 — module conditional load.
# Leave blank to DISABLE module (admin endpoint sẽ 404, KHÔNG crash app).
# Set 32-byte key (hex 64 chars OR base64 44 chars) để enable encryption.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TIMING_ALERT_ENCRYPTION_KEY=
# Default poll interval per race (configurable per-config 60-300s).
TIMING_ALERT_DEFAULT_POLL_INTERVAL=90
# Telegram chat_id receive CRITICAL alerts (Phase 1C).
# Empty trong dev/test, set khi triển khai Phase 1C.
TIMING_ALERT_TELEGRAM_CHAT_ID=
