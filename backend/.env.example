# Core
NODE_ENV=development
NETWORK=testnet
PORT=8081

# MongoDB (main)
MONGODB_URL=mongodb://localhost:27018
MONGODB_DB_NAME=5bib_result

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=5bib-result-secret

# AWS S3 (main bucket for race assets)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=5bib-assets
AWS_S3_CDN_URL=

# Mailchimp transactional
MAILCHIMP_API_KEY=

# 5BIB Platform MySQL (readonly — leave blank to disable)
PLATFORM_DB_HOST=
PLATFORM_DB_PORT=3306
PLATFORM_DB_NAME=
PLATFORM_DB_USER=
PLATFORM_DB_PASS=

# Team Management — Volunteer MySQL (leave blank to disable the module)
VOLUNTEER_DB_HOST=
VOLUNTEER_DB_PORT=3306
VOLUNTEER_DB_NAME=
VOLUNTEER_DB_USER=
VOLUNTEER_DB_PASS=

# Team Management — misc
MAGIC_TOKEN_EXPIRES_DAYS=7
TEAM_S3_BUCKET=5sport-media
TEAM_CREW_BASE_URL=https://crew.5bib.com
TEAM_EMAIL_FROM=info@5bib.com
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=60

# Cloudflare Turnstile (free captcha) — used for /recover endpoints.
# Get free keys at https://dash.cloudflare.com → Turnstile → Add Site.
# If unset, backend skips verification (dev / self-hosted only — NEVER in prod).
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Result Image Creator v1.0
# Max concurrent canvas renders (per backend instance). Tune per CPU count;
# 8 is safe on a 4-vCPU VPS (napi-rs/canvas is native multi-threaded).
RENDER_MAX_CONCURRENT=8
# Public URL embedded in QR code + share links drawn on the image.
RESULT_PUBLIC_URL=https://result.5bib.com

# Event Tracking — behavioral analytics ingest from 5bib.com frontend
# Must match NEXT_PUBLIC_ANALYTICS_API_KEY on 5bib.com. Use a random secret in prod.
ANALYTICS_API_KEY=dev-analytics-key-local

# Timing Miss Alert v1.0 — module conditional load.
# Leave blank to DISABLE module (admin endpoint sẽ 404, KHÔNG crash app).
# Set 32-byte key (hex 64 chars OR base64 44 chars) để enable encryption.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TIMING_ALERT_ENCRYPTION_KEY=
# Default poll interval per race (configurable per-config 60-300s).
TIMING_ALERT_DEFAULT_POLL_INTERVAL=90
# Telegram chat_id receive CRITICAL alerts (Phase 1C).
# Empty trong dev/test, set khi triển khai Phase 1C.
TIMING_ALERT_TELEGRAM_CHAT_ID=

# FEATURE-030 — 5BIB provider info dùng trong reconciliation DOCX/XLSX render.
# Defensive defaults trong code (`src/config/index.ts`) — env unset → fallback
# đúng info Danny đã chốt 2026-05-13. Override các vars dưới nếu thông tin pháp
# lý / bank thay đổi (KHÔNG cần redeploy code, chỉ restart container).
PROVIDER_COMPANY_NAME=CÔNG TY CỔ PHẦN 5BIB
PROVIDER_ADDRESS=Tầng 9, Tòa nhà Hồ Gươm Plaza (tòa văn phòng), Số 102 Phố Trần Phú, Phường Hà Đông, TP Hà Nội, Việt Nam
PROVIDER_TAX_CODE=0110398986
PROVIDER_PHONE=0373398986
PROVIDER_REPRESENTATIVE_NAME=Nguyễn Bình Minh
PROVIDER_REPRESENTATIVE_TITLE=Giám Đốc
PROVIDER_BANK_ACCOUNT=110398986
PROVIDER_BANK_NAME=Ngân hàng Quân Đội MB

# FEATURE-076 — MISA Meinvoice daily reconcile + alert.
# Module conditional load (cần platform DB + MISA env). KHÔNG outage nếu
# unset — Layer 2 verify skip, alert chỉ dựa Layer 1.
#
# MISA credentials — set per environment.
# SANDBOX: https://testapi.meinvoice.vn/api/integration
# PROD:    https://api.meinvoice.vn/api/integration
MISA_AIO_BASE_URL=https://api.meinvoice.vn/api/integration
MISA_APP_ID=
MISA_TAX_CODE=
MISA_USERNAME=
MISA_PASSWORD=
# CSV race IDs để bật e-invoice reconcile. Vd "140,220".
INVOICE_RECONCILE_ENABLED_RACES=
# Age thresholds (hours). Defaults: 12h/20h/24h.
INVOICE_RECONCILE_AGE_WARN_HOURS=12
INVOICE_RECONCILE_AGE_CRITICAL_HOURS=20
INVOICE_RECONCILE_AGE_BREACHED_HOURS=24
# F-076 BR-14a — BOT + CHANNEL ISOLATION TUYỆT ĐỐI.
# KHÔNG dùng chung TELEGRAM_BOT_TOKEN (claim bot existing PROD).
# F-076 dùng bot RIÊNG @invoice_5bib_daily_bot (Danny tạo qua @BotFather).
INVOICE_RECONCILE_TELEGRAM_BOT_TOKEN=
INVOICE_RECONCILE_TELEGRAM_CHAT_ID=
# Email fallback (CSV). Chỉ gửi khi Telegram fail.
INVOICE_ALERT_EMAILS=

# FEATURE-085 — Igloo Insurance partner API (daily auto-order + admin manual-create).
# Production portal đứng trước nhà bảo hiểm GIC. Auth = header X-API-Key.
# DAILY_ENABLED=false = kill-switch tắt toàn bộ auto-push (cron). Bật khi sẵn sàng.
IGLOO_BASE_URL=https://api-insurance.5solution.vn
IGLOO_API_KEY=
IGLOO_DAILY_COUNT=10
IGLOO_DAILY_ENABLED=false
IGLOO_CRON_HOUR=9
